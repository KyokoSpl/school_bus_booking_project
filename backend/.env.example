# Server Konfiguration
HOST=127.0.0.1
PORT=8080
RUST_LOG=info,sqlx=warn,actix_web=info

# Datenbank (Docker: siehe docker-compose.yml)
DATABASE_URL=mysql://busbooker:busbooker_dev_password@localhost:3306/busbooker

# JWT Konfiguration
JWT_SECRET=dein-super-geheimes-jwt-secret-mindestens-32-zeichen
JWT_EXPIRATION_HOURS=24

# E-Mail Konfiguration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@sonnenschein-reisen.de
SMTP_PASSWORD=smtp-password
SMTP_FROM_EMAIL=noreply@sonnenschein-reisen.de
SMTP_FROM_NAME=Sonnenschein Reisen

# Frontend URL (für E-Mail-Links)
FRONTEND_URL=http://localhost:5173
