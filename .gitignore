# Dependencies
node_modules/
jspm_packages/

# Build outputs
dist/
dist-ssr/
build/

# npm
npm-debug.log*
package-lock.json

# Yarn
yarn-debug.log*
yarn-error.log*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# pnpm
pnpm-debug.log*
.pnpm-store/

